{
  "columns": [
    {"name":"name",                 "type":"Nullable(String)",       "description":"Human-friendly display name."},
    {"name":"description",          "type":"Nullable(String)",       "description":""},
    {"name":"displayName",          "type":"Nullable(String)",       "description":""},
    {"name":"pathSegment",          "type":"String",                 "description":"Path-reconstruction segment. Empty string means the entity contributes no path segment."},
