{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://connectors.netwrix.io/schema/connector.schema.json",
  "title": "Connector Manifest",
  "description": "Declarative manifest for a Netwrix DSPM connector. Lives at the root of a connector source tree as connector.yaml. Single source of truth for the source_types row, Setup form, runtime image binding, and capability gating.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "connectors.netwrix.io/v1"
    },
    "kind": {
      "type": "string",
      "const": "Connector"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "displayName", "version"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,62}[a-z0-9]$",
          "description": "Globally unique slug. Lowercase, hyphen-separated. Becomes source_types.name."
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Shown in the Add Connector picker."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([-+][0-9A-Za-z.-]+)?$",
          "description": "Semver. Becomes source_types.version."
        },
        "vendor": {
          "type": "string",
          "default": "local",
          "description": "netwrix | community | local | <org>"
        },
        "icon": {
          "type": "string",
          "description": "Path (relative to manifest) to an SVG/PNG icon."
        },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["image", "capabilities"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository"],
          "properties": {
            "repository": {
              "type": "string",
              "description": "OCI image reference without tag/digest, e.g. ghcr.io/netwrix/connectors/box."
            },
            "tag":    { "type": "string" },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$",
              "description": "Required for signed installs (Phase 3). Optional in prototype."
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            },
            "signing": {
              "type": "object",
              "description": "Cosign keyless or key-based signing config. Optional in prototype.",
              "properties": {
                "cosign": {
                  "type": "object",
                  "properties": {
                    "certificateIdentity":   { "type": "string" },
                    "certificateOidcIssuer": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "capabilities": {
          "type": "object",
          "required": ["operations"],
          "properties": {
            "scanTypes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["access_scan", "sensitive_data_scan", "sync"]
              },
              "uniqueItems": true,
              "description": "Which scan types this connector supports. Drives the buttons rendered for a Source."
            },
            "operations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": ["test_connection", "discover", "scan", "fetch", "apply"]
              },
              "uniqueItems": true,
              "description": "Verbs the image dispatches at runtime. test_connection is conventionally always present."
            },
            "additionalProcesses": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key", "displayName"],
                "properties": {
                  "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
                  "displayName": { "type": "string" },
                  "description": { "type": "string" }
                },
                "additionalProperties": false
              },
              "description": "Optional post-processing handlers callable via run-process."
            }
          }
        },
        "credentials": {
          "type": "object",
          "description": "Credential schema. Drives the Service Account form. Stored as a k8s Secret reference at runtime.",
          "required": ["schema"],
          "properties": {
            "schema": { "$ref": "#/$defs/jsonSchemaSubset" }
          }
        },
        "source": {
          "type": "object",
          "description": "Per-source configuration schema. Drives the Create Source form.",
          "required": ["schema"],
          "properties": {
            "schema": { "$ref": "#/$defs/jsonSchemaSubset" }
          }
        },
        "scan": {
          "type": "object",
          "description": "Per-scan-execution config schema. Drives any per-execution overrides.",
          "properties": {
            "schema": { "$ref": "#/$defs/jsonSchemaSubset" }
          }
        },
        "resources": {
          "type": "object",
          "description": "k8s resource requests/limits applied to the connector pod.",
          "properties": {
            "requests": { "$ref": "#/$defs/resourceMap" },
            "limits":   { "$ref": "#/$defs/resourceMap" }
          }
        },
        "runtime": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["container"],
              "default": "container",
              "description": "Only 'container' supported in v1. Wasm reserved for future."
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1,
              "default": 14400
            },
            "network": {
              "type": "object",
              "properties": {
                "egress": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "FQDNs the connector needs to reach. Advisory NetworkPolicy generated from this."
                }
              }
            }
          }
        },
        "permissions": {
          "type": "object",
          "description": "What the connector is allowed to emit. Sidecar enforces.",
          "properties": {
            "findingTypes": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(access_grant|object_metadata|sensitive_match|custom:[a-z][a-z0-9_.-]*)$"
              },
              "uniqueItems": true,
              "description": "Allowed values for the 'type' field of findings. Three built-ins; custom: prefix for extensions."
            }
          }
        },
        "auth": {
          "type": "object",
          "description": "Authentication methods this connector accepts. Drives the 'Auth Type' picker in the Add Source wizard. Connectors that don't need auth (web crawler, public APIs) can omit the section entirely or declare a single method with type=none.",
          "properties": {
            "methods": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["none", "basic", "bearer", "api_key", "service_account", "custom"],
                    "description": "Auth model. 'none' for anonymous, 'basic'/'bearer'/'api_key' for inline credentials, 'service_account' to reuse the AA26 SA picker, 'custom' for connector-defined fields."
                  },
                  "displayName": {
                    "type": "string",
                    "description": "Label shown in the Auth Type dropdown."
                  },
                  "description": {
                    "type": "string",
                    "description": "Helper text shown below the dropdown when this method is selected."
                  },
                  "fields": {
                    "$ref": "#/$defs/jsonSchemaSubset",
                    "description": "Fields the user fills in when they pick this method (renders just like spec.source.schema). Standard JSON Schema with x-display, x-secret, etc. Use type=none to skip."
                  },
                  "accountTypes": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["username_password", "client_id_secret", "ssh_private_key", "client_id_certificate"]
                    },
                    "description": "When type=service_account, restricts the SA picker to these flavors."
                  }
                },
                "additionalProperties": false
              },
              "uniqueItems": true,
              "description": "Available auth methods for this connector. If the array is empty or omitted, the wizard skips the auth step."
            },
            "scope": {
              "type": "string",
              "enum": ["per-source", "per-group"],
              "default": "per-source",
              "description": "per-source: each Source in the group gets its own credentials (Databricks PAT, Box token). per-group: one credential bundle covers every Source (AD bind credentials)."
            }
          },
          "additionalProperties": false
        },
        "sourceTypes": {
          "type": "array",
          "minItems": 1,
          "description": "Source types this connector emits. Each becomes a source_type_registry row at upload time and defines an ingestion mapping the runtime applies to matching findings.",
          "items": {
            "type": "object",
            "required": ["name", "domain", "ingestion"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Z][A-Za-z0-9]{1,62}$",
                "description": "PascalCase. Becomes source_type_registry.sourceTypeName. Must be globally unique across all connectors."
              },
              "displayName": {
                "type": "string",
                "maxLength": 64
              },
              "domain": {
                "type": "string",
                "enum": ["Artifact", "Computer", "Group", "Principal", "Role", "SystemObject"],
                "description": "Maps to domain_type_properties.domainName."
              },
              "ingestion": {
                "type": "object",
                "required": ["target", "mapping"],
                "additionalProperties": false,
                "properties": {
                  "target": {
                    "type": "string",
                    "enum": ["entities"],
                    "description": "v1 supports only the entities table."
                  },
                  "mapping": {
                    "type": "object",
                    "additionalProperties": false,
                    "description": "Map from entities columns to dotted-path expressions evaluated against each finding. Only the cross-domain allow-list is permitted.",
                    "properties": {
                      "name":                 { "$ref": "#/$defs/jsonPathExpr" },
                      "description":          { "$ref": "#/$defs/jsonPathExpr" },
                      "displayName":          { "$ref": "#/$defs/jsonPathExpr" },
                      "pathSegment":          { "$ref": "#/$defs/jsonPathExpr" },
                      "parentId":             { "$ref": "#/$defs/jsonPathExpr" },
                      "isContainer":          { "$ref": "#/$defs/jsonPathExpr" },
                      "hasContent":           { "$ref": "#/$defs/jsonPathExpr" },
                      "sourceSystemId":       { "$ref": "#/$defs/jsonPathExpr" },
                      "sourceSystemIdType":   { "$ref": "#/$defs/jsonPathExpr" },
                      "sizeBytes":            { "$ref": "#/$defs/jsonPathExpr" },
                      "itemCount":            { "$ref": "#/$defs/jsonPathExpr" },
                      "descendantCount":      { "$ref": "#/$defs/jsonPathExpr" },
                      "extension":            { "$ref": "#/$defs/jsonPathExpr" },
                      "contentType":          { "$ref": "#/$defs/jsonPathExpr" },
                      "contentHash":          { "$ref": "#/$defs/jsonPathExpr" },
                      "contentHashAlgorithm": { "$ref": "#/$defs/jsonPathExpr" },
                      "createdDate":          { "$ref": "#/$defs/jsonPathExpr" },
                      "modifiedDate":         { "$ref": "#/$defs/jsonPathExpr" },
                      "lastAccessedDate":     { "$ref": "#/$defs/jsonPathExpr" }
                    }
                  },
                  "additionalProperties": {
                    "type": "object",
                    "description": "Map of namespaced extra-keys to path expressions. Each key MUST match '^<metadata.name>\\.[a-zA-Z][a-zA-Z0-9_]*$'.",
                    "additionalProperties": { "$ref": "#/$defs/jsonPathExpr" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "jsonPathExpr": {
      "type": "string",
      "pattern": "^\\$(\\.[a-zA-Z_][a-zA-Z0-9_]*)+$",
      "description": "Restricted dotted-path. Root '$' followed by one or more '.<identifier>' segments. Examples: '$.object.url', '$.evidence.raw.etag'."
    },
    "jsonSchemaSubset": {
      "type": "object",
      "description": "Embedded JSON Schema used to render forms. Validates as a JSON Schema document.",
      "properties": {
        "type":       { "type": "string" },
        "required":   { "type": "array", "items": { "type": "string" } },
        "properties": { "type": "object" }
      }
    },
    "resourceMap": {
      "type": "object",
      "patternProperties": {
        "^(cpu|memory|ephemeral-storage)$": { "type": ["string", "number"] }
      },
      "additionalProperties": false
    }
  }
}
